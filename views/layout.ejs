<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> — MythosCore</title>
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet"/>
</head>
<body>

<!-- ===================== NAVBAR ===================== -->
<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <div class="logo-icon">M</div>
      <span>MythosCore</span>
    </a>
    <ul class="nav-links">
      <li><a href="/" class="<%= title==='Home'?'active':'' %>">Home</a></li>
      <li><a href="/resources" class="<%= title==='Resources'?'active':'' %>">Resources</a></li>
      <li><a href="/forum" class="<%= title==='Forum'?'active':'' %>">Forum</a></li>
      <li><a href="/discord" class="<%= title==='Discord'?'active':'' %>">Discord</a></li>
      <li><a href="/subscribe" class="<%= title==='Subscribe'?'active':'' %>">Subscribe</a></li>
    </ul>
    <div class="nav-right">
      <% if (user) { %>
        <a href="/messages" class="nav-icon-btn" title="Messages">
          ✉
          <% if (unreadCount > 0) { %><span class="badge"><%= unreadCount %></span><% } %>
        </a>
        <div class="nav-user-menu">
          <img src="<%= user.avatar %>" class="nav-avatar" onerror="this.src='/img/default-avatar.png'"/>
          <div class="nav-dropdown">
            <a href="/profile"><strong><%= user.username %></strong><span class="rank-tag <%= user.role %>"><%= user.site_rank %></span></a>
            <hr/>
            <a href="/profile">My Profile</a>
            <a href="/messages">Messages</a>
            <% if (user.role === 'admin') { %><a href="/admin">Admin Panel</a><% } %>
            <% if (user.role === 'moderator' || user.role === 'admin') { %><a href="/messages/broadcast">Broadcast</a><% } %>
            <hr/>
            <a href="/auth/logout" class="logout-link">Log Out</a>
          </div>
        </div>
      <% } else { %>
        <button class="btn btn-outline" onclick="openAuth('login')">Log In</button>
        <button class="btn btn-primary" onclick="openAuth('register')">Sign Up</button>
      <% } %>
    </div>
    <button class="nav-burger" onclick="toggleMobileMenu()" aria-label="Menu">☰</button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/">Home</a>
    <a href="/resources">Resources</a>
    <a href="/forum">Forum</a>
    <a href="/discord">Discord</a>
    <a href="/subscribe">Subscribe</a>
    <% if (user) { %>
      <a href="/profile">Profile</a>
      <a href="/messages">Messages</a>
      <% if (user.role === 'admin') { %><a href="/admin">Admin Panel</a><% } %>
      <a href="/auth/logout">Log Out</a>
    <% } else { %>
      <button onclick="openAuth('login')">Log In</button>
      <button onclick="openAuth('register')">Sign Up</button>
    <% } %>
  </div>
</nav>

<!-- Flash messages -->
<% if (success && success.length) { %><div class="flash flash-success"><%= success[0] %><button onclick="this.parentElement.remove()">✕</button></div><% } %>
<% if (error && error.length) { %><div class="flash flash-error"><%= error[0] %><button onclick="this.parentElement.remove()">✕</button></div><% } %>

<!-- ===================== PAGE CONTENT ===================== -->
<main>
  <%- body %>
</main>

<!-- ===================== FOOTER ===================== -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="logo-icon">M</div>
      <span>MythosCore</span>
    </div>
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/resources">Resources</a>
      <a href="/forum">Forum</a>
      <a href="/discord">Discord</a>
      <a href="/subscribe">Subscribe</a>
    </div>
    <p class="footer-copy">© <%= new Date().getFullYear() %> MythosCore. All rights reserved.</p>
  </div>
</footer>

<!-- ===================== AUTH MODAL ===================== -->
<div class="modal-overlay" id="authOverlay" onclick="closeAuth(event)">
  <div class="modal-box" id="authBox">
    <button class="modal-close" onclick="closeAuthModal()">✕</button>

    <!-- Tabs -->
    <div class="auth-tabs">
      <button class="auth-tab active" id="tab-login" onclick="switchTab('login')">Log In</button>
      <button class="auth-tab" id="tab-register" onclick="switchTab('register')">Sign Up</button>
    </div>

    <!-- Social login -->
    <div class="social-btns">
      <a href="/auth/google" class="btn-social google">
        <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Continue with Google
      </a>
      <a href="/auth/github" class="btn-social github">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        Continue with GitHub
      </a>
    </div>

    <div class="auth-divider"><span>or</span></div>

    <!-- Login form -->
    <form id="loginForm" onsubmit="submitAuth(event,'login')">
      <div class="field-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="your@email.com" required/>
      </div>
      <div class="field-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required/>
      </div>
      <div class="auth-msg" id="loginMsg"></div>
      <button type="submit" class="btn btn-primary full-width">Log In</button>
    </form>

    <!-- Register form -->
    <form id="registerForm" onsubmit="submitAuth(event,'register')" style="display:none">
      <div class="field-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="CoolPlayer123" required/>
      </div>
      <div class="field-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="your@email.com" required/>
      </div>
      <div class="field-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Min. 6 characters" required/>
      </div>
      <div class="auth-msg" id="registerMsg"></div>
      <button type="submit" class="btn btn-primary full-width">Create Account</button>
    </form>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
